# Copy to .env and adjust. All values are optional --
# src/utils/env.ts has working defaults for prod.

# Which environment block to use: prod | qa
ENV=prod

# Override the deployed URLs without editing code.
# BASE_URL must end with a trailing slash.
BASE_URL=https://buildbuddy50.github.io/novastore/
API_URL=https://novastore-fk1k.onrender.com/api

# Seeded administrator account.
ADMIN_EMAIL=admin@nova.com
ADMIN_PASSWORD=admin123
